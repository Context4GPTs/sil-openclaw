{
  "description": "Log all bash commands with timestamps",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\" + (now | strftime(\"%Y-%m-%d %H:%M:%S\")) + \"] \" + .tool_input.command + \" # \" + (.tool_input.description // \"no description\")' >> ~/.claude/bash-history.log"
          }
        ]
      }
    ]
  }
}
