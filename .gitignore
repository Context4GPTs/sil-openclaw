*~
.DS_Store

# Obsidian — track shared vault config (app.json, core-plugins.json,
# community-plugins.json, plugin manifests + js). Ignore per-machine state.
.obsidian/workspace
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/*/data.json
.claude/scheduled_tasks.lock

