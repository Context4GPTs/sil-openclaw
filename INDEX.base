filters:
  and:
    - file.ext == "md"
    - type == "card"
    - file.name != "_TEMPLATE"
    - file.path.startsWith("cards/")
formulas:
  days_since_update: if(updated, (today() - date(updated)).days, "")
  age_days: if(created, (today() - date(created)).days, "")
properties:
  title:
    displayName: Title
  status:
    displayName: Status
  work_type:
    displayName: Type
  agents:
    displayName: Agents
  priority:
    displayName: Priority
  branch:
    displayName: Branch
  pr:
    displayName: PR
  created:
    displayName: Created
  updated:
    displayName: Updated
  formula.days_since_update:
    displayName: Idle (d)
  formula.age_days:
    displayName: Age (d)
views:
  - type: kanban-view
    name: Board
    filters:
      and:
        - not:
            - file.inFolder("cards/done")
            - file.inFolder("cards/abandoned")
    order:
      - work_type
      - priority
      - agents
      - formula.days_since_update
    cardTitleProperty: title
    groupByProperty: status
    wrapPropertyValues: true
    columnOrders:
      note.status:
        - backlog
        - discovery
        - stand-by
        - in-dev
        - review
        - distilling
        - pr-ready
    columnColors:
      note.status:
        backlog: blue
        discovery: purple
        stand-by: yellow
        in-dev: orange
        review: cyan
        distilling: pink
        pr-ready: green
  - type: kanban-view
    name: Board by agent
    filters:
      and:
        - not:
            - file.inFolder("cards/done")
            - file.inFolder("cards/abandoned")
        - status != "backlog"
    order:
      - work_type
      - priority
      - formula.days_since_update
    cardTitleProperty: title
    groupByProperty: status
    swimlaneByProperty: agents
    wrapPropertyValues: true
    columnOrders:
      note.status:
        - discovery
        - stand-by
        - in-dev
        - review
        - distilling
        - pr-ready
    columnColors:
      note.status:
        discovery: purple
        stand-by: yellow
        in-dev: orange
        review: cyan
        distilling: pink
        pr-ready: green
  - type: table
    name: WIP by agent
    filters:
      and:
        - not:
            - file.inFolder("cards/done")
            - file.inFolder("cards/abandoned")
        - status != "backlog"
    groupBy:
      property: agents
      direction: ASC
    order:
      - title
      - status
      - work_type
      - priority
      - branch
      - updated
      - formula.days_since_update
  - type: table
    name: By work type
    filters:
      and:
        - not:
            - file.inFolder("cards/done")
            - file.inFolder("cards/abandoned")
    groupBy:
      property: work_type
      direction: ASC
    order:
      - title
      - status
      - priority
      - agents
      - created
      - updated
  - type: table
    name: Stale (idle > 7d)
    filters:
      and:
        - not:
            - file.inFolder("cards/done")
            - file.inFolder("cards/abandoned")
        - status != "backlog"
        - updated
        - (today() - date(updated)).days > 7
    order:
      - title
      - status
      - agents
      - updated
      - formula.days_since_update
  - type: table
    name: Done
    filters:
      and:
        - file.inFolder("cards/done")
    order:
      - title
      - work_type
      - updated
      - pr
  - type: table
    name: Abandoned
    filters:
      and:
        - file.inFolder("cards/abandoned")
    order:
      - title
      - work_type
      - updated
